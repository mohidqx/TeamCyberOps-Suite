# 🎯 Host Header Injection → Basic Detection
# Target: marionnaud.fr

curl -sk -H "Host: evil.com" https://marionnaud.fr/ | grep -i "evil.com"

curl -sk -H "Host: marionnaud.fr.evil.com" https://marionnaud.fr/ -v 2>&1 | grep -i location

curl -sk -H "Host: localhost" https://marionnaud.fr/ -v 2>&1 | grep -E "200|301|500"

curl -sk -H "Host: 127.0.0.1" https://marionnaud.fr/ -v 2>&1

curl -sk -H "Host: 0.0.0.0" https://marionnaud.fr/ -D -


